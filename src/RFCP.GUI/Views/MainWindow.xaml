<Window x:Class="RFCP.GUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RFCP - Robot Flexible Control Platform"
        Width="1680"
        Height="980"
        MinWidth="1366"
        MinHeight="768"
        Background="#08151F">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#08151F" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#102535" />
        <SolidColorBrush x:Key="PanelSecondaryBrush" Color="#173549" />
        <SolidColorBrush x:Key="PanelTertiaryBrush" Color="#1D4157" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#EAF0F4" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8F4FF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9EB8CB" />
        <SolidColorBrush x:Key="AccentBrush" Color="#00A7C4" />
        <SolidColorBrush x:Key="AccentPositiveBrush" Color="#2DE38F" />
        <SolidColorBrush x:Key="AccentWarningBrush" Color="#FFB547" />
        <SolidColorBrush x:Key="BorderBrush" Color="#2A4E66" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F7FBFF" />
            <Setter Property="BorderBrush" Value="#B4C7D5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#133447" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#173549" />
            <Setter Property="BorderBrush" Value="#2A5F7C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BottomNavButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Background" Value="#1B3F56" />
        </Style>

        <Style x:Key="KpiCardStyle" TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Background" Value="#113248" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#26465C" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="210" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource PanelBackgroundBrush}" Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="瑞辉智能柔性机器人控制平台" Foreground="{StaticResource TextPrimaryBrush}" FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="Deterministic Control • Action Pipeline • Plugin Drivers" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0,3,0,0" />
                </StackPanel>

                <UniformGrid Grid.Column="1" Rows="1" Columns="3" Margin="12,0,12,0">
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="系统状态" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                            <TextBlock Text="RUNNING" Foreground="{StaticResource AccentPositiveBrush}" FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="控制模式" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                            <TextBlock Text="AUTO" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiCardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="通信质量" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                            <TextBlock Text="98.7%" Foreground="{StaticResource AccentWarningBrush}" FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Column="2" Background="#0D2030" BorderBrush="#284A62" BorderThickness="1" CornerRadius="8" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="事件总线状态：正常（InMemoryEventBus）" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" />
                        <TextBlock Grid.Row="1" Margin="0,4,0,0" Text="动作管线：已装载 24 个步骤，周期 20ms" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                        <TextBlock Grid.Row="2" Margin="0,4,0,0" Text="最近告警：无严重告警" Foreground="#B7D4E6" FontSize="13" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="2024-09-12 16:05:51" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" HorizontalAlignment="Right" />
                    <TextBlock Text="User: OEM-User / Group: OEM" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Right" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource PanelSecondaryBrush}" Style="{StaticResource PanelBorderStyle}" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Content="开始示例任务" Command="{Binding StartSampleTaskCommand}" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="SemiBold" Margin="0" />

                <Border Grid.Column="1" Margin="12,0,0,0" Background="#0E2435" CornerRadius="8" BorderBrush="#2A4F66" BorderThickness="1" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Date" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" />
                        <TextBlock Grid.Column="1" Text="Time" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" />
                        <TextBlock Grid.Column="2" Text="ID" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" />
                        <TextBlock Grid.Column="3" Text="Event" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Grid.Column="0" Margin="0,10,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False" Margin="0,0,0,10">
                        <TextBlock Text="MFB1 工艺总览" FontSize="28" FontWeight="Bold" Foreground="#173246" />
                        <Border DockPanel.Dock="Right" Background="#173549" BorderBrush="#2F627E" BorderThickness="1" CornerRadius="6" Padding="10,5">
                            <TextBlock Text="控制周期：20ms" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" />
                        </Border>
                    </DockPanel>

                    <Grid Grid.Row="1" Background="#F7FBFF">
                        <Canvas Margin="8">
                            <Rectangle Width="680" Height="460" Stroke="#4F6D80" StrokeThickness="4" RadiusX="12" RadiusY="12" Canvas.Left="44" Canvas.Top="24" />
                            <Rectangle Width="380" Height="210" Stroke="#67869B" StrokeThickness="3" RadiusX="8" RadiusY="8" Canvas.Left="274" Canvas.Top="64" />
                            <Rectangle Width="280" Height="130" Stroke="#9AAAB5" Fill="#EFF3F7" StrokeThickness="2" RadiusX="6" RadiusY="6" Canvas.Left="548" Canvas.Top="414" />
                            <Rectangle Width="300" Height="130" Stroke="#9AAAB5" Fill="#EFF3F7" StrokeThickness="2" RadiusX="6" RadiusY="6" Canvas.Left="850" Canvas.Top="414" />
                            <TextBlock Text="Mixing Valve" FontSize="28" FontWeight="SemiBold" Foreground="#1C3C52" Canvas.Left="598" Canvas.Top="458" />
                            <TextBlock Text="Drain Box" FontSize="30" FontWeight="SemiBold" Foreground="#1C3C52" Canvas.Left="930" Canvas.Top="470" />
                            <TextBlock Text="工艺流程区（管路图 / 阀门 / 传感器 / 动画状态）" Foreground="#5E7483" FontSize="22" Canvas.Left="260" Canvas.Top="290" />
                        </Canvas>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#E2EAF0" Style="{StaticResource PanelBorderStyle}" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <GroupBox Header="动作管线操作">
                        <WrapPanel>
                            <Button Content="Initialize" Style="{StaticResource ActionButtonStyle}" MinWidth="100" />
                            <Button Content="PreProcess" Style="{StaticResource ActionButtonStyle}" MinWidth="100" />
                            <Button Content="DoProcess" Style="{StaticResource ActionButtonStyle}" MinWidth="100" />
                            <Button Content="PostProcess" Style="{StaticResource ActionButtonStyle}" MinWidth="100" />
                            <Button Content="Manual" Style="{StaticResource ActionButtonStyle}" MinWidth="90" />
                            <Button Content="Auto" Style="{StaticResource ActionButtonStyle}" MinWidth="90" Background="{StaticResource AccentBrush}" Foreground="White" />
                        </WrapPanel>
                    </GroupBox>

                    <UniformGrid Grid.Row="1" Rows="2" Columns="2">
                        <GroupBox Header="Chemical" Margin="0,0,8,8"><Button Content="Supply" Style="{StaticResource ActionButtonStyle}" /></GroupBox>
                        <GroupBox Header="Drain" Margin="0,0,0,8"><Button Content="Start" Style="{StaticResource ActionButtonStyle}" /></GroupBox>
                        <GroupBox Header="DIW Operation" Margin="0,0,8,0"><Button Content="Start" Style="{StaticResource ActionButtonStyle}" /></GroupBox>
                        <GroupBox Header="QDR"><Button Content="Check" Style="{StaticResource ActionButtonStyle}" /></GroupBox>
                    </UniformGrid>

                    <UniformGrid Grid.Row="2" Rows="1" Columns="2">
                        <GroupBox Header="Megasonics 1" Margin="0,0,8,0"><Button Content="Select" Style="{StaticResource ActionButtonStyle}" /></GroupBox>
                        <GroupBox Header="Megasonics 2"><Button Content="Select" Style="{StaticResource ActionButtonStyle}" /></GroupBox>
                    </UniformGrid>

                    <UniformGrid Grid.Row="3" Rows="1" Columns="2">
                        <GroupBox Header="Lift" Margin="0,0,8,0"><Button Content="MoveTo" Style="{StaticResource ActionButtonStyle}" /></GroupBox>
                        <GroupBox Header="Agitation"><Button Content="On / Off" Style="{StaticResource ActionButtonStyle}" /></GroupBox>
                    </UniformGrid>

                    <GroupBox Grid.Row="4" Header="系统状态与运行说明" Margin="0">
                        <TextBlock Margin="8" FontSize="14" Foreground="#173246" TextWrapping="Wrap" Text="{Binding Status}" />
                    </GroupBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Background="{StaticResource PanelBackgroundBrush}" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="模块导航" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0,0,0,10" />
                <Button Content="Equipment Control" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="Material Movement" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="SPM" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="HQDR" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="DHF" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="QDR" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="MFB1" Style="{StaticResource SidebarButtonStyle}" Background="#1F5875" BorderBrush="{StaticResource AccentBrush}" />
                <Button Content="MFB2" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="Dryer" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="CC" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="WTS" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="GTR" Style="{StaticResource SidebarButtonStyle}" />
                <Button Content="CSB" Style="{StaticResource SidebarButtonStyle}" Margin="0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource PanelTertiaryBrush}" Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="OverView" Style="{StaticResource BottomNavButtonStyle}" />
                <Button Grid.Column="1" Content="Jobs" Style="{StaticResource BottomNavButtonStyle}" />
                <Button Grid.Column="2" Content="Recipe" Style="{StaticResource BottomNavButtonStyle}" />
                <Button Grid.Column="3" Content="Parameter" Style="{StaticResource BottomNavButtonStyle}" />
                <Button Grid.Column="4" Content="System" Style="{StaticResource BottomNavButtonStyle}" />
                <Button Grid.Column="5" Content="Alarms" Style="{StaticResource BottomNavButtonStyle}" />
                <Button Grid.Column="6" Content="Log" Style="{StaticResource BottomNavButtonStyle}" />
                <Button Grid.Column="7" Content="User Mgmt" Style="{StaticResource BottomNavButtonStyle}" />
                <Button Grid.Column="8" Content="OEM" Style="{StaticResource BottomNavButtonStyle}" />
                <Button Grid.Column="9" Content="Exit" Style="{StaticResource BottomNavButtonStyle}" Background="{StaticResource AccentBrush}" BorderBrush="#54CAE0" />
            </Grid>
        </Border>
    </Grid>
</Window>
